+/* ===========================
+   EDITORIAL / HAOQI-STYLE REWORK
+   Monochrome, quiet, typography-led.
+   Overrides the maximalist rules above.
+=========================== */
+
+.hero {
+  position: relative;
+  width: 100%;
+  min-height: 100vh;
+  height: auto;
+  overflow: hidden;
+  isolation: isolate;
+
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+
+  padding: 0;
+  background: #0a0a0a;
+  color: #f5f5f5;
+}
+
+.quietGrid {
+  position: absolute;
+  inset: 0;
+  z-index: 0;
+  pointer-events: none;
+  background-image:
+    linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
+    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
+  background-size: 96px 96px;
+  mask-image: radial-gradient(circle at 50% 40%, black, transparent 80%);
+}
+
+/* ---- top nav ---- */
+
+.nav {
+  position: relative;
+  z-index: 20;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+
+  padding: 32px 6vw;
+
+  font-family: var(--font-geist-mono), monospace;
+  font-size: 12px;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+  color: rgba(245, 245, 245, 0.7);
+}
+
+.navLeft .navLogo {
+  color: #f5f5f5;
+  font-weight: 600;
+  letter-spacing: 0.18em;
+}
+
+.navCenter {
+  display: flex;
+  gap: 28px;
+}
+
+.navCenter a {
+  color: rgba(245, 245, 245, 0.6);
+  transition: color 0.3s ease;
+}
+
+.navCenter a:hover {
+  color: #f5f5f5;
+}
+
+.navRight {
+  display: flex;
+  align-items: center;
+  gap: 20px;
+}
+
+.navToggle {
+  background: none;
+  border: none;
+  color: rgba(245, 245, 245, 0.6);
+  font: inherit;
+  letter-spacing: inherit;
+  text-transform: inherit;
+  cursor: pointer;
+  transition: color 0.3s ease;
+}
+
+.navToggle:hover {
+  color: #f5f5f5;
+}
+
+.navToggle span {
+  margin-left: 4px;
+  opacity: 0.6;
+}
+
+.clock {
+  display: flex;
+  align-items: baseline;
+  gap: 8px;
+  font-variant-numeric: tabular-nums;
+  color: rgba(245, 245, 245, 0.85);
+}
+
+.clockZone {
+  color: rgba(245, 245, 245, 0.45);
+  font-size: 11px;
+}
+
+@media (max-width: 900px) {
+  .navCenter {
+    display: none;
+  }
+  .nav {
+    padding: 24px 6vw;
+  }
+}
+
+/* ---- editorial headline block ---- */
+
+.heroContent {
+  position: relative;
+  z-index: 10;
+  width: min(1200px, 88%);
+  margin: auto;
+  padding: 10vh 0 8vh;
+}
+
+.editorial {
+  max-width: 900px;
+}
+
+.editorialTitle {
+  display: flex;
+  flex-direction: column;
+  gap: 0.05em;
+
+  font-family: var(--font-serif), Georgia, serif;
+  font-weight: 400;
+  font-style: italic;
+  line-height: 1.05;
+  letter-spacing: -0.01em;
+  text-transform: none;
+
+  font-size: clamp(2.75rem, 6vw, 5.5rem);
+  color: #f5f5f5;
+}
+
+.editorialTitle span {
+  display: block;
+}
+
+.editorialBio {
+  margin-top: 2.25rem;
+  max-width: 46ch;
+
+  font-family: var(--font-geist-sans), sans-serif;
+  font-size: clamp(0.95rem, 1.1vw, 1.05rem);
+  line-height: 1.7;
+  color: rgba(245, 245, 245, 0.6);
+}
+
+.editorialLinks {
+  display: flex;
+  gap: 40px;
+  margin-top: 3rem;
+}
+
+.editorialLink {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+
+  font-family: var(--font-geist-mono), monospace;
+  font-size: 13px;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  color: #f5f5f5;
+
+  padding-bottom: 2px;
+  border-bottom: 1px solid rgba(245, 245, 245, 0.25);
+  transition: border-color 0.3s ease, opacity 0.3s ease;
+}
+
+.editorialLink:hover {
+  border-color: rgba(245, 245, 245, 0.9);
+}
+
+.editorialLink span {
+  transition: transform 0.3s ease;
+}
+
+.editorialLink:hover span {
+  transform: translateX(3px);
+}
+
+@media (max-width: 640px) {
+  .editorialLinks {
+    flex-direction: column;
+    gap: 18px;
+  }
+}
