+"use client";
+
+import { motion, type Variants } from "framer-motion";
+import styles from "./Hero.module.css";
+
+const fadeUp: Variants = {
+  hidden: { opacity: 0, y: 24 },
+  visible: (delay = 0) => ({
+    opacity: 1,
+    y: 0,
+    transition: {
+      duration: 0.9,
+      delay,
+      ease: [0.22, 1, 0.36, 1] as const,
+    },
+  }),
+};
+
+export default function HeroHeadline() {
+  return (
+    <div className={styles.editorial}>
+      <motion.h1
+        className={styles.editorialTitle}
+        initial="hidden"
+        animate="visible"
+      >
+        <motion.span custom={0} variants={fadeUp}>
+          Product &amp; Engineering.
+        </motion.span>
+        <motion.span custom={0.08} variants={fadeUp}>
+          Building with care.
+        </motion.span>
+      </motion.h1>
+
+      <motion.p
+        className={styles.editorialBio}
+        initial="hidden"
+        animate="visible"
+        custom={0.3}
+        variants={fadeUp}
+      >
+        We&apos;re Techzilla, a small studio designing and shipping
+        digital products at scale. Outside client work, we build
+        tools that make teams faster.
+      </motion.p>
+    </div>
+  );
+}
